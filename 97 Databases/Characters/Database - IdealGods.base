views:
  - type: cards
    name: Table
    filters:
      and:
        - file.inFolder("03 Pantheon")
        - file.tags.contains("Ideal")
    order:
      - file.name
      - PantheonHeight
      - domain
      - Parents
    sort:
      - property: file.name
        direction: ASC
    columnSize:
      note.domain: 141
    image: note.art
    cardSize: 170
    imageAspectRatio: 1
